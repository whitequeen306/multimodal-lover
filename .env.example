SERVER_PORT=8080
FRONTEND_PORT=80
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=your-mysql-password
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your-redis-password
# DashScope API Key（必填，VL + Chat 共用）
DASHSCOPE_API_KEY=sk-your-api-key

# 模型组合：最高效且兼顾成本（答辩 ACG 演示可将 VL 改为 qwen3-vl-plus）
LOVER_VISION_MODEL=qwen3-vl-flash
LOVER_CHAT_MODEL=deepseek-v4-flash
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=multimodal-lover
MINIO_PUBLIC_BASE_URL=http://localhost:9000
